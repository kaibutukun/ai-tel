// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & User
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  avatarUrl    String?
  // scrypt ハッシュ "salt:hash" 形式 / 招待経由で作成した場合は null
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyMembers CompanyMember[]
  invitations    Invitation[]
  adminRole      Boolean         @default(false)
}

// ============================================================
// Company (テナント)
// ============================================================

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  phoneMain String?
  address   String?
  website   String?
  industry  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              CompanyMember[]
  invitations          Invitation[]
  phoneNumbers         PhoneNumber[]
  phoneNumberRequests  PhoneNumberRequest[]
  callFlows            CallFlow[]
  faqs                 FAQ[]
  documents            Document[]
  callSessions         CallSession[]
  notificationSettings NotificationSetting[]
  subscription         Subscription?
  usageRecords         UsageRecord[]
  invoices             Invoice[]
  adminNotes           String?
}

model CompanyMember {
  id        String    @id @default(cuid())
  companyId String
  userId    String
  role      Role      @default(GENERAL)
  invitedAt DateTime  @default(now())
  joinedAt  DateTime?
  isActive  Boolean   @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
}

// 管理者: 全設定を操作可能 / 一般: 通話ログ・FAQ等の参照のみ
enum Role {
  ADMIN
  GENERAL
}

// パスワード未設定ユーザー向けの招待トークン。
// 招待 URL を発行して相手に渡し、相手がパスワードを設定するときに consume する。
model Invitation {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  companyId String
  role      Role
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ============================================================
// Phone Number
// ============================================================

model PhoneNumber {
  id          String   @id @default(cuid())
  companyId   String?
  number      String   @unique
  displayName String?
  callFlowId  String?
  transferTo  String?
  // NTT CPaaS / Infobip 側の番号IDなど、プロバイダ管理画面で照合できるID。
  providerNumberId String? @map("twilioSid")
  provider         String  @default("ntt-cpaas")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  callFlow      CallFlow?     @relation(fields: [callFlowId], references: [id])
  businessHours BusinessHour[]
  callSessions  CallSession[]
}

model PhoneNumberRequest {
  id        String                     @id @default(cuid())
  companyId String
  status    PhoneNumberRequestStatus  @default(PENDING)
  note      String?
  adminNote String?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum PhoneNumberRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model BusinessHour {
  id            String  @id @default(cuid())
  phoneNumberId String
  dayOfWeek     Int
  openTime      String
  closeTime     String
  isClosed      Boolean @default(false)

  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
}

// ============================================================
// Call Flow (ノードベース)
// ============================================================

model CallFlow {
  id          String     @id @default(cuid())
  companyId   String
  name        String
  description String?
  status      FlowStatus @default(DRAFT)
  // React Flow の nodes/edges を JSON で保存
  flowJson    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phoneNumbers PhoneNumber[]
  callSessions CallSession[]
}

enum FlowStatus {
  PUBLISHED
  DRAFT
}

// ============================================================
// FAQ
// ============================================================

model FAQ {
  id        String   @id @default(cuid())
  companyId String
  category  String?
  question  String
  answer    String
  // Legacy: UI/APIでは使用しない。既存DBの破壊的変更を避けるため残す。
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  callSessionFaqs CallSessionFaq[]
}

// ============================================================
// Document (AI回答用の参考資料)
// ============================================================

model Document {
  id          String         @id @default(cuid())
  companyId   String
  name        String
  type        DocumentType
  url         String?
  content     String?
  status      DocumentStatus @default(PROCESSING)
  usedInFlows String[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  chunks  DocumentChunk[]
}

enum DocumentType {
  PDF
  URL
  TEXT
}

enum DocumentStatus {
  PROCESSING
  AVAILABLE
  ERROR
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  content    String
  embedding  Bytes?
  chunkIndex Int
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ============================================================
// Call Session (通話ログ)
// ============================================================

model CallSession {
  id              String     @id @default(cuid())
  companyId       String
  phoneNumberId   String?
  callFlowId      String?
  // CPaaS プロバイダ側の通話ID。イベントから同じ通話ログを更新するために使う。
  providerCallId  String?    @map("twilioCallSid")
  callerNumber    String?
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  result          CallResult @default(AI_RESOLVED)
  recordingUrl    String?
  operatorNote    String?
  createdAt       DateTime   @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phoneNumber PhoneNumber? @relation(fields: [phoneNumberId], references: [id])
  callFlow    CallFlow?    @relation(fields: [callFlowId], references: [id])
  transcripts CallTranscript[]
  summaries   CallSummary[]
  sessionFaqs CallSessionFaq[]
}

enum CallResult {
  AI_RESOLVED
  TRANSFERRED
  CALLBACK_REQUESTED
  NO_ANSWER
  VOICEMAIL
}

model CallTranscript {
  id            String   @id @default(cuid())
  callSessionId String
  speaker       String
  content       String
  timestamp     Float
  createdAt     DateTime @default(now())

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
}

model CallSummary {
  id            String   @id @default(cuid())
  callSessionId String   @unique
  summary       String
  extractedData Json?
  sentiment     String?
  createdAt     DateTime @default(now())

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
}

model CallSessionFaq {
  id            String @id @default(cuid())
  callSessionId String
  faqId         String

  callSession CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  faq         FAQ         @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([callSessionId, faqId])
}


// ============================================================
// Notification Setting
// ============================================================

model NotificationSetting {
  id         String           @id @default(cuid())
  companyId  String
  type       NotificationType
  target     String
  conditions String[]
  template   String?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  EMAIL
  SLACK
  WEBHOOK
}

// ============================================================
// Plan & Billing
// ============================================================

// プランは TRIAL / PAID の2種類だけ。料金や上限は会社ごとに Subscription 側で設定する。
model Plan {
  id        String   @id @default(cuid())
  name      String
  type      PlanType @unique
  createdAt DateTime @default(now())

  subscriptions Subscription[]
}

enum PlanType {
  TRIAL
  PAID
}

model Subscription {
  id                 String             @id @default(cuid())
  companyId          String             @unique
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  // 会社ごとの個別設定（運営者が編集する）
  monthlyPrice       Int                @default(0)
  maxMinutesPerMonth Int                @default(30)
  trialEndsAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

model UsageRecord {
  id               String   @id @default(cuid())
  companyId        String
  year             Int
  month            Int
  totalCalls       Int      @default(0)
  totalMinutes     Int      @default(0)
  aiResolvedCount  Int      @default(0)
  transferredCount Int      @default(0)
  extraMinutes     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year, month])
}

model Invoice {
  id        String        @id @default(cuid())
  companyId String
  year      Int
  month     Int
  subtotal  Int
  tax       Int
  total     Int
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  lineItems Json
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year, month])
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}
